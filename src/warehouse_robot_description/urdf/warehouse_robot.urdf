<?xml version="1.0"?>
<robot name="warehouse_robot">

  <!-- 🔥 MATERIALS -->
  <material name="black"><color rgba="0.05 0.05 0.05 1"/></material>
  <material name="blue"><color rgba="0.1 0.2 0.8 1"/></material>
  <material name="silver"><color rgba="0.7 0.7 0.7 1"/></material>
  <material name="red"><color rgba="0.8 0.1 0.1 1"/></material>
  <material name="green"><color rgba="0.1 0.8 0.1 1"/></material>
  <material name="yellow"><color rgba="0.9 0.8 0.1 1"/></material>

  <!-- BASE FOOTPRINT -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <!-- BASE -->
  <link name="base_link">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.02" ixy="0" ixz="0"
               iyy="0.02" iyz="0"
               izz="0.04"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="package://warehouse_robot_description/meshes/base_link.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <!-- lifted base -->
    <collision>
      <origin xyz="0 0 0.07"/>
      <geometry>
        <box size="0.40 0.30 0.08"/>
      </geometry>
    </collision>
  </link>

  <!-- LEFT WHEEL -->
  <link name="left_wheel">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.00014" ixy="0" ixz="0"
               iyy="0.00014" iyz="0"
               izz="0.00025"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="package://warehouse_robot_description/meshes/left_wheel_link_1.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.05 0.165 0.03"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- RIGHT WHEEL -->
  <link name="right_wheel">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.00014" ixy="0" ixz="0"
               iyy="0.00014" iyz="0"
               izz="0.00025"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="package://warehouse_robot_description/meshes/right_wheel_link_1.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.05 -0.165 0.03"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 🔥 WHEEL FRICTION -->
  <gazebo reference="left_wheel">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
  </gazebo>

  <!-- CASTER -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="silver"/>
    </visual>

    <collision>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.10 0 0.03"/>
  </joint>

  <!-- 🔥 REMOVE DRAG -->
  <gazebo reference="caster_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- TOP STRUCTURE -->
  <link name="top_part">
    <visual>
      <geometry>
        <mesh filename="package://warehouse_robot_description/meshes/plate_link_1.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="green"/>
    </visual>
  </link>

  <joint name="top_part_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_part"/>
    <origin xyz="0 0 0.13"/>
  </joint>

  <!-- LIDAR -->
  <link name="lidar_link">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>

    <visual>
      <geometry>
        <mesh filename="package://warehouse_robot_description/meshes/lidar_link_1.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.30"/>
  </joint>

  <!-- CAMERA -->
  <link name="camera_link">
    <visual>
      <geometry>
        <mesh filename="package://warehouse_robot_description/meshes/cam_link_1.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="yellow"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.2 0 0.2"/>
  </joint>

  <!-- DIFF DRIVE -->
  <gazebo>
    <plugin name="diff_drive_controller"
            filename="libgazebo_ros_diff_drive.so">

      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.33</wheel_separation>
      <wheel_diameter>0.10</wheel_diameter>

      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
    </plugin>
  </gazebo>

  <!-- 3D VELodyne -->
  <gazebo reference="lidar_link">
    <sensor type="ray" name="velodyne">

      <visualize>true</visualize>
      <update_rate>10</update_rate>

      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <min_angle>-3.14</min_angle>
            <max_angle>3.14</max_angle>
          </horizontal>

          <vertical>
            <samples>16</samples>
            <min_angle>-0.26</min_angle>
            <max_angle>0.26</max_angle>
          </vertical>
        </scan>

        <range>
          <min>0.3</min>
          <max>20.0</max>
        </range>
      </ray>

      <plugin name="gazebo_ros_velodyne"
              filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=/velodyne_points</remapping>
        </ros>
        <frame_name>lidar_link</frame_name>
        <output_type>sensor_msgs/PointCloud2</output_type>
      </plugin>

    </sensor>
  </gazebo>

</robot>